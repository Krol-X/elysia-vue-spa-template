{
  "name": "elysia-vue-spa-template",
  "description": "A minimal full-stack template with Vue frontend and Elysia backend, compiled into a single executable",
  "version": "1.0.0",
  "workspaces": [
    "app/*"
  ],
  "scripts": {
    "dev": "bun --bun bin/dev.ts",
    "dev:api": "bun run --cwd app/api dev",
    "dev:web": "bun run --cwd app/web dev",
    "db:generate": "bun run --cwd app/api db:generate",
    "db:migrate": "bun run --cwd app/api db:migrate",
    "db:seed": "bun run --cwd app/api db:seed",
    "build": "bun run build:web && bun run build:api",
    "build:api": "bun run --cwd app/api build",
    "build:web": "bun run --cwd app/web build",
    "preview": "bun run --cwd dist ./app",
    "preview:migrate": "bun run --cwd dist ./app db:migrate",
    "preview:seed": "bun run --cwd dist ./app db:seed",
    "format": "prettier app --write"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "prettier": "^3.8.1"
  },
  "peerDependencies": {
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2"
  }
}
